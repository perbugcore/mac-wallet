QMAKE_PRL_TARGET = QtNetwork
QMAKE_PRL_CONFIG = shared lib_bundle
QMAKE_PRL_VERSION = 6.11.0
QMAKE_PRL_LIBS = -F$$[QT_INSTALL_LIBS] -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
QMAKE_PRL_LIBS_FOR_CMAKE = -F$$[QT_INSTALL_LIBS];-framework;QtCore;-framework IOKit;-framework DiskArbitration;-framework UniformTypeIdentifiers
